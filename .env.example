# ===========================================
# Assistent-Refactored Environment Variables
# Версия: refactored-2025-v2
# ===========================================

# Telegram Bot Credentials
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_NAME=@MyownAssistentbot
N8N_CREDENTIALS_TELEGRAM_ID=your_telegram_credential_id_in_n8n

# OpenAI API Credentials (основная модель для воркфлоу)
OPENAI_API_KEY=your_openai_api_key
N8N_CREDENTIALS_OPENAI_ID=your_openai_credential_id_in_n8n

# Google Calendar OAuth2 Credentials (для полноценной работы календаря)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALENDAR_ACCOUNT_NAME=Google Calendar account
N8N_CREDENTIALS_GOOGLE_CALENDAR_ID=your_google_calendar_credential_id_in_n8n

# Опционально: GigaChat API (если будете интегрировать)
GIGACHAT_API_KEY=your_gigachat_api_key
GIGACHAT_CLIENT_ID=your_gigachat_client_id
GIGACHAT_CLIENT_SECRET=your_gigachat_client_secret
N8N_CREDENTIALS_GIGACHAT_ID=your_gigachat_credential_id_in_n8n

# Опционально: Groq API (альтернатива OpenAI)
GROQ_API_KEY=your_groq_api_key
N8N_CREDENTIALS_GROQ_ID=your_groq_credential_id_in_n8n

# Настройки воркфлоу
WORKFLOW_VERSION=refactored-2025-v2
LOG_LEVEL=info
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=10

# Таймзона для календаря
TIMEZONE=Asia/Yekaterinburg
